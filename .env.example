# Copy file này thành .env và điền thông tin
# OpenAI-compatible API endpoint (GLM, OpenAI, v.v.)
OPENAI_BASE_URL=https://api.xxxx.net/v1
OPENAI_API_KEY=sk-xxx...

# Model chat (OpenAI-compatible)
CHAT_MODEL=glm-5.2

# Embedding dùng model local (all-MiniLM-L6-v2) — không cần API
# Không cần cấu hình thêm, model tự tải lần đầu (~80MB)

# PostgreSQL - Aiven Database
PG_HOST=your-pg-host.aivencloud.com
PG_PORT=12345
PG_USER=avnadmin
PG_PASSWORD=your-password
PG_DBNAME=your-database-name
PG_SSLMODE=require
